<?xml version="1.0" encoding="UTF-8" ?>
<Application
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:Gym_Logs.Converters"
    x:Class="Gym_Logs.App">

    <Application.Resources>
        <ResourceDictionary>
            <x:Double x:Key="UIScale">1</x:Double>
            <converters:ScaleConverter x:Key="ScaleConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/CorePalette.xaml" />
                <ResourceDictionary Source="Resources/Styles/CurrentTheme.xaml" />
                <ResourceDictionary Source="Resources/Styles/Brushes.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
