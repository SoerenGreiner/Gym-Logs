<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Gym_Logs.Resources.Styles.AppThemes.Light">

    <!-- ========= BASE LAYERS ========= -->
    <Color x:Key="Deep">#FFFFFF</Color>
    <Color x:Key="Surface">#F2F2F2</Color>
    <Color x:Key="SurfaceSoft">#FFFFFF</Color>
    <Color x:Key="Glow">#FFD54F</Color>
    <Color x:Key="Accent">#FF9800</Color>

    <!-- ========= TEXT ========= -->
    <Color x:Key="PrimaryTextColor">#000000</Color>
    <Color x:Key="SecondaryTextColor">#666666</Color>

    <!-- ========= STATES ========= -->
    <Color x:Key="CalendarToday">#FFD54F</Color>
    <Color x:Key="CalendarWorkout">#81C784</Color>
    <Color x:Key="CalendarBody">#4DB6AC</Color>

    <!-- ========= RADIAL GRADIENTS ========= -->

    <!-- Normal -->
    <RadialGradientBrush x:Key="CalendarNormalBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource SurfaceSoft}" Offset="0"/>
        <GradientStop Color="{DynamicResource Surface}" Offset="1"/>
    </RadialGradientBrush>

    <!-- Header -->
    <RadialGradientBrush x:Key="CalendarHeaderBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource SurfaceSoft}" Offset="0"/>
        <GradientStop Color="{DynamicResource Glow}" Offset="1"/>
    </RadialGradientBrush>

    <!-- Today -->
    <RadialGradientBrush x:Key="CalendarTodayBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource CalendarToday}" Offset="0"/>
        <GradientStop Color="{DynamicResource Glow}" Offset="1"/>
    </RadialGradientBrush>

    <!-- Workout -->
    <RadialGradientBrush x:Key="CalendarWorkoutBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource CalendarWorkout}" Offset="0"/>
        <GradientStop Color="{DynamicResource Accent}" Offset="1"/>
    </RadialGradientBrush>

    <!-- Body -->
    <RadialGradientBrush x:Key="CalendarBodyBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource CalendarBody}" Offset="0"/>
        <GradientStop Color="{DynamicResource Accent}" Offset="1"/>
    </RadialGradientBrush>

    <!-- Inactive -->
    <RadialGradientBrush x:Key="CalendarInactiveBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="#DDDDDD" Offset="0"/>
        <GradientStop Color="#AAAAAA" Offset="1"/>
    </RadialGradientBrush>

</ResourceDictionary>