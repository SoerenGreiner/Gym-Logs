<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Gym_Logs.Resources.Styles.AppThemes.MonoBlueDark">

    <!-- ========= BASE LAYERS ========= -->
    <Color x:Key="Background">#0B1E3D</Color>

    <Color x:Key="PrimaryLight">#1C3F7A</Color>
    <Color x:Key="PrimaryDark">#122E5C</Color>

    <Color x:Key="SecondaryLight">#3A7BD5</Color>
    <Color x:Key="SecondaryDark">#2A5FA0</Color>

    <Color x:Key="Accent">#00BFFF</Color>
    
    <!-- ========= TEXT ========= -->
    <Color x:Key="PrimaryTextColor">#E3F2FD</Color>
    <Color x:Key="SecondaryTextColor">#AFC7DD</Color>

    <!-- ========= RADIAL GRADIENTS ========= -->
    <RadialGradientBrush x:Key="CalendarNormalBrush"
                 Center="0,0" Radius="1">
        <GradientStop Color="#F2F2F2" Offset="0"/>
        <GradientStop Color="#BFBFBF" Offset="1"/>
    </RadialGradientBrush>
    <Color x:Key="CalendarNormalTextColor">#101828</Color>

    <RadialGradientBrush x:Key="CalendarHeaderBrush"
                 Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource SecondaryLight}" Offset="0"/>
        <GradientStop Color="{DynamicResource SecondaryDark}" Offset="1"/>
    </RadialGradientBrush>
    <Color x:Key="CalendarHeaderTextColor">#FFFFFF</Color>

    <RadialGradientBrush x:Key="CalendarTodayBrush"
                 Center="0,0" Radius="1">
        <GradientStop Color="#F0E68C" Offset="0"/>
        <GradientStop Color="#C9B458" Offset="1"/>
    </RadialGradientBrush>
    <Color x:Key="CalendarTodayTextColor">#000000</Color>

    <RadialGradientBrush x:Key="CalendarWorkoutBrush"
                 Center="0,0" Radius="1">
        <GradientStop Color="#8FB3E8" Offset="0"/>
        <GradientStop Color="#4A76B8" Offset="1"/>
    </RadialGradientBrush>
    <Color x:Key="CalendarWorkoutTextColor">#FFFFFF</Color>

    <RadialGradientBrush x:Key="CalendarBodyBrush"
                 Center="0,0" Radius="1">
        <GradientStop Color="#9FD3A1" Offset="0"/>
        <GradientStop Color="#4F8F5A" Offset="1"/>
    </RadialGradientBrush>
    <Color x:Key="CalendarBodyTextColor">#101828</Color>

    <RadialGradientBrush x:Key="CalendarInactiveBrush"
                 Center="0,0" Radius="1">
        <GradientStop Color="#BFBFBF" Offset="0"/>
        <GradientStop Color="#737373" Offset="1"/>
    </RadialGradientBrush>
    <Color x:Key="CalendarInactiveTextColor">#FFFFFF</Color>

</ResourceDictionary>