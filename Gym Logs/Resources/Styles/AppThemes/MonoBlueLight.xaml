<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Gym_Logs.Resources.Styles.AppThemes.MonoBlueLight">

    <!-- ========= BASE LAYERS ========= -->
    <Color x:Key="Deep">#E3F2FD</Color>
    <Color x:Key="Surface">#BBDEFB</Color>
    <Color x:Key="SurfaceSoft">#E3F2FD</Color>
    <Color x:Key="Glow">#90CAF9</Color>
    <Color x:Key="Accent">#1565C0</Color>

    <!-- ========= TEXT ========= -->
    <Color x:Key="PrimaryTextColor">#0D47A1</Color>
    <Color x:Key="SecondaryTextColor">#1976D2</Color>

    <!-- ========= STATES ========= -->
    <Color x:Key="CalendarToday">#42A5F5</Color>
    <Color x:Key="CalendarWorkout">#1E88E5</Color>
    <Color x:Key="CalendarBody">#64B5F6</Color>

    <!-- ========= RADIAL GRADIENTS ========= -->

    <!-- Normal -->
    <RadialGradientBrush x:Key="CalendarNormalBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource SurfaceSoft}" Offset="0"/>
        <GradientStop Color="{DynamicResource Surface}" Offset="1"/>
    </RadialGradientBrush>

    <!-- Header -->
    <RadialGradientBrush x:Key="CalendarHeaderBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource SurfaceSoft}" Offset="0"/>
        <GradientStop Color="{DynamicResource Glow}" Offset="1"/>
    </RadialGradientBrush>

    <!-- Today -->
    <RadialGradientBrush x:Key="CalendarTodayBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource CalendarToday}" Offset="0"/>
        <GradientStop Color="{DynamicResource Glow}" Offset="1"/>
    </RadialGradientBrush>

    <!-- Workout -->
    <RadialGradientBrush x:Key="CalendarWorkoutBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource CalendarWorkout}" Offset="0"/>
        <GradientStop Color="{DynamicResource Accent}" Offset="1"/>
    </RadialGradientBrush>

    <!-- Body -->
    <RadialGradientBrush x:Key="CalendarBodyBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="{DynamicResource CalendarBody}" Offset="0"/>
        <GradientStop Color="{DynamicResource Accent}" Offset="1"/>
    </RadialGradientBrush>

    <!-- Inactive -->
    <RadialGradientBrush x:Key="CalendarInactiveBrush"
                         Center="0,0" Radius="1">
        <GradientStop Color="#B3B3B3" Offset="0"/>
        <GradientStop Color="#737373" Offset="1"/>
    </RadialGradientBrush>

</ResourceDictionary>