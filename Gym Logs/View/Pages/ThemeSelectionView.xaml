<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gym_Logs.ViewModel.Pages"
             xmlns:controls="clr-namespace:Gym_Logs.View.Controls"
             x:Class="Gym_Logs.View.Pages.ThemeSelectionView"
             BackgroundColor="{DynamicResource Background}">

    <CollectionView ItemsSource="{Binding AvailableThemes}" SelectionMode="None"
                    Margin="12">
        <CollectionView.ItemsLayout>
            <GridItemsLayout Orientation="Vertical" Span="2"
                             HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <controls:ThemeItemView BindingContext="{Binding .}">
                    <controls:ThemeItemView.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ThemeSelectionViewModel}}, Path=ThemeSelectedCommand}"
                            CommandParameter="{Binding .}" />
                    </controls:ThemeItemView.GestureRecognizers>
                </controls:ThemeItemView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>