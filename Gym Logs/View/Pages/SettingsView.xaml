<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gym_Logs.ViewModel"
             x:Class="Gym_Logs.View.SettingsView"
             BackgroundColor="{DynamicResource AppBackgroundColor}">

    <ContentPage.Resources>
        <Style x:Key="ThemePreviewBox" TargetType="Border">
            <Setter Property="WidthRequest" Value="22"/>
            <Setter Property="HeightRequest" Value="22"/>
            <Setter Property="Stroke" Value="Black"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <Border HeightRequest="60"
            Padding="12"
            Margin="0,10"
            Stroke="{DynamicResource Accent}"
            StrokeThickness="1">

        <Border.Background>
            <RadialGradientBrush Center="0,0" Radius="1">
                <GradientStop Color="{Binding CurrentTheme.PrimaryLight}" Offset="0"/>
                <GradientStop Color="{Binding CurrentTheme.PrimaryDark}" Offset="1"/>
            </RadialGradientBrush>
        </Border.Background>

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="6"/>
        </Border.StrokeShape>

        <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center" ColumnSpacing="10">

            <Label Text="Theme auswählen"
                   VerticalOptions="Center"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource PrimaryTextColor}" />

            <HorizontalStackLayout Grid.Column="1"
                                   Spacing="6"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">

                <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding CurrentTheme.PrimaryLight}" />
                <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding CurrentTheme.PrimaryDark}" />
                <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding CurrentTheme.SecondaryLight}" />
                <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding CurrentTheme.SecondaryDark}" />
                <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding CurrentTheme.Accent}" />

                <Label Text="{Binding CurrentTheme.DisplayName}"
                       VerticalOptions="Center"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource PrimaryTextColor}" />
            </HorizontalStackLayout>

            <Label Grid.Column="2"
                   Text="›"
                   FontSize="26"
                   VerticalOptions="Center"
                   HorizontalOptions="End"
                   TextColor="{DynamicResource PrimaryTextColor}" />
        </Grid>

        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding OpenThemeSelectionCommand}" />
        </Border.GestureRecognizers>

    </Border>
</ContentPage>