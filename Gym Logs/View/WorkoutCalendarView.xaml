<?xml version="1.0" encoding="utf-8" ?>
<ContentPage  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gym_Logs.ViewModels"
             x:Class="Gym_Logs.View.WorkoutCalendarView"
             x:Name="WorkoutCalendarPage">
    
    <StackLayout Padding="10" Spacing="10">

        <!-- Monatsname -->
        <Frame BackgroundColor="#2196F3" CornerRadius="8" Padding="10">
            <Label Text="{Binding CurrentMonthName}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontAttributes="Bold"
                   TextColor="White"
                   FontSize="22"/>
        </Frame>

        <!-- Kalender-Grid -->
        <Grid x:Name="CalendarGrid"
              RowSpacing="5"
              ColumnSpacing="5">

            <!-- Wochentage -->
            <Label Text="Mo" Grid.Row="0" Grid.Column="0" HorizontalOptions="Center"/>
            <Label Text="Di" Grid.Row="0" Grid.Column="1" HorizontalOptions="Center"/>
            <Label Text="Mi" Grid.Row="0" Grid.Column="2" HorizontalOptions="Center"/>
            <Label Text="Do" Grid.Row="0" Grid.Column="3" HorizontalOptions="Center"/>
            <Label Text="Fr" Grid.Row="0" Grid.Column="4" HorizontalOptions="Center"/>
            <Label Text="Sa" Grid.Row="0" Grid.Column="5" HorizontalOptions="Center"/>
            <Label Text="So" Grid.Row="0" Grid.Column="6" HorizontalOptions="Center"/>
        </Grid>

    </StackLayout>
</ContentPage>