<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gym_Logs.View.Controls.ThemeItemView">

    <ContentView.Resources>
        <Style x:Key="ThemePreviewBox" TargetType="Border">
            <Setter Property="WidthRequest" Value="22"/>
            <Setter Property="HeightRequest" Value="22"/>
            <Setter Property="Stroke" Value="Black"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </ContentView.Resources>

    <Border Stroke="{Binding Accent}" StrokeThickness="1" Padding="8">
        <Border.Background>
            <RadialGradientBrush Center="0,0" Radius="1">
                <GradientStop Color="{Binding PrimaryLight}" Offset="0"/>
                <GradientStop Color="{Binding PrimaryDark}" Offset="1"/>
            </RadialGradientBrush>
        </Border.Background>

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="6"/>
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="6">
            <Label Text="{Binding DisplayName}" 
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   TextColor="{Binding PrimaryTextColor}" />

            <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding PrimaryLight}" />
                <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding PrimaryDark}" />
                <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding SecondaryLight}" />
                <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding SecondaryDark}" />
                <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding Accent}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>