<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gym_Logs.View.Controls.ThemeItemView">

    <!-- ===================== RESOURCES ===================== -->
    <ContentView.Resources>
        <Style x:Key="ThemePreviewBox" TargetType="Border">
            <!-- Width/Height scaled via UIScale -->
            <Setter Property="WidthRequest" 
                    Value="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=22}" />
            <Setter Property="HeightRequest" 
                    Value="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=22}" />
            <Setter Property="Stroke" Value="Black"/>
            <Setter Property="StrokeThickness" 
                    Value="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=1}" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=4}" />
                </Setter.Value>
            </Setter>
        </Style>
    </ContentView.Resources>

    <!-- ===================== MAIN BORDER ===================== -->
    <Border Stroke="{DynamicResource PrimaryAccent}" 
            StrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=1}" 
            Padding="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=8}" >
        <Border.Background>
            <RadialGradientBrush Center="0,0" Radius="1">
                <GradientStop Color="{Binding PrimaryStartColor}" Offset="0"/>
                <GradientStop Color="{Binding PrimaryEndColor}" Offset="1"/>
            </RadialGradientBrush>
        </Border.Background>
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=6}"/>
        </Border.StrokeShape>

        <!-- ===================== GRID LAYOUT ===================== -->
        <Grid ColumnDefinitions="*,Auto,*" RowDefinitions="*"
              ColumnSpacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=6}"
              RowSpacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=6}">

            <!-- LEFT COLOR BOX -->
            <Border Grid.Column="0" 
                    WidthRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=40}" 
                    HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=40}" 
                    Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=2}" 
                    HorizontalOptions="End">
                <Border.Background>
                    <RadialGradientBrush Center="0,0" Radius="1">
                        <GradientStop Color="{Binding PrimaryStartColor}" Offset="0"/>
                        <GradientStop Color="{Binding PrimaryEndColor}" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=6}"/>
                </Border.StrokeShape>
            </Border>

            <!-- MIDDLE THEME NAME AND PREVIEW -->
            <VerticalStackLayout Grid.Column="1" 
                                 Spacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=6}" 
                                 HorizontalOptions="Center">

                <Label Text="{Binding LocalizedDisplayName}" 
                       HorizontalOptions="Center"
                       FontAttributes="Bold"
                       FontSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=16}"
                       TextColor="{Binding PrimaryTextColorColor}" />

                <HorizontalStackLayout Spacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=4}" 
                                       HorizontalOptions="Center">
                    <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding PrimaryStartColor}" />
                    <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding PrimaryEndColor}" />
                    <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding SecondaryStartColor}" />
                    <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding SecondaryEndColor}" />
                    <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{Binding PrimaryAccentColor}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- RIGHT COLOR BOX -->
            <Border Grid.Column="2" 
                    WidthRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=40}" 
                    HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=40}" 
                    Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=2}" 
                    HorizontalOptions="Start">
                <Border.Background>
                    <RadialGradientBrush Center="0,0" Radius="1">
                        <GradientStop Color="{Binding SecondaryStartColor}" Offset="0"/>
                        <GradientStop Color="{Binding SecondaryEndColor}" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=6}"/>
                </Border.StrokeShape>
            </Border>

        </Grid>
    </Border>
</ContentView>