<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gym_Logs.ViewModels.Pages"
             x:Class="Gym_Logs.View.Controls.FlyoutItemView"
             HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='48'}"
             HorizontalOptions="Fill">

    <StackLayout>

        <!-- ================= TAP BORDER ================= -->
        <Border x:Name="TapBorder"
                HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='45'}"
                HorizontalOptions="Fill"
                Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='0'}"
                Padding="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='10,6'}"
                Background="{DynamicResource SecondaryBrush}">

            <Border.Triggers>
                <DataTrigger TargetType="Border"
                             Binding="{Binding IsPressed}"
                             Value="True">
                    <Setter Property="Background"
                            Value="{DynamicResource Accent}" />
                </DataTrigger>
            </Border.Triggers>

            <!-- ================= GRID ================= -->
            <Grid ColumnDefinitions="Auto,*"
                  VerticalOptions="Center"
                  ColumnSpacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='10'}">

                <!-- Icon -->
                <Image Source="{Binding Icon}"
                       WidthRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='22'}"
                       HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='22'}"
                       VerticalOptions="Center"/>

                <!-- Label -->
                <Label Grid.Column="1"
                       Text="{Binding Title}"
                       Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='10,0,0,0'}"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource PrimaryTextColor}"
                       VerticalOptions="Center"/>

            </Grid>

            <!-- ================= TAP GESTURE ================= -->
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AppShellViewModel}}, Path=NavigateCommand}"
                                      CommandParameter="{Binding}" />
            </Border.GestureRecognizers>

        </Border>

        <!-- Divider -->
        <BoxView HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='1'}"
                 BackgroundColor="{DynamicResource Accent}"
                 HorizontalOptions="Fill"/>

    </StackLayout>
</ContentView>

