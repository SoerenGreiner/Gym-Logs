<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gym_Logs.ViewModels.Pages"
             x:Class="Gym_Logs.Views.Pages.ExercisePickerView"
             Title="Übung auswählen">

    <VerticalStackLayout Padding="10" Spacing="10">
        <SearchBar Placeholder="Übung suchen..."
                   Text="{Binding SearchText, Mode=TwoWay}" />

        <CollectionView ItemsSource="{Binding FilteredExercises}" SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{Binding ImagePath}" WidthRequest="50" HeightRequest="50" />

                        <VerticalStackLayout Grid.Column="1" Padding="5">
                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16"/>
                            <Label Text="{Binding MachineNumber}" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ExercisePickerViewModel}}, Path=SelectExerciseCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>