<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gym_Logs.ViewModel.Pages"
             xmlns:controls="clr-namespace:Gym_Logs.View.Controls"
             x:Class="Gym_Logs.View.Pages.ThemeSelectionView">

    <CollectionView ItemsSource="{Binding ThemeCategories}"
                    SelectionMode="None">

        <CollectionView.ItemTemplate>
            <DataTemplate>

                <StackLayout>

                    <!-- ================= CATEGORY HEADER ================= -->
                    <Border HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='50'}"
                            Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='2'}"
                            Stroke="{DynamicResource PrimaryAccent}"
                            StrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='1'}">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='6'}"/>
                        </Border.StrokeShape>

                        <Border.Triggers>

                            <DataTrigger TargetType="Border"
                                         Binding="{Binding IsExpanded}"
                                         Value="True">

                                <Setter Property="Background">
                                    <Setter.Value>
                                        <RadialGradientBrush Center="0,0" Radius="1">
                                            <GradientStop Color="{DynamicResource PrimaryStart}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource SecondaryAccent}" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Setter.Value>
                                </Setter>

                            </DataTrigger>

                            <DataTrigger TargetType="Border"
                                         Binding="{Binding IsExpanded}"
                                         Value="False">

                                <Setter Property="Background">
                                    <Setter.Value>
                                        <RadialGradientBrush Center="0,0" Radius="1">
                                            <GradientStop Color="{DynamicResource PrimaryStart}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource PrimaryEnd}" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Setter.Value>
                                </Setter>

                            </DataTrigger>

                        </Border.Triggers>

                        <Grid ColumnDefinitions="*,Auto"
                              VerticalOptions="Center"
                              ColumnSpacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='10'}">

                            <Label Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='20'}"
                                   TextColor="{DynamicResource PrimaryTextColor}"
                                   FontAttributes="Bold"
                                   Margin="15,5,0,0">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ThemeSelectionViewModel}}, Path=ToggleCategoryCommand}"
                                        CommandParameter="{Binding .}" />
                                </Label.GestureRecognizers>

                            </Label>

                            <Label Grid.Column="1"
                                   Text="›"
                                   FontSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='26'}"
                                   FontAttributes="Bold"
                                   Margin="0,0,15,10"
                                   HorizontalOptions="End"
                                   TextColor="{DynamicResource PrimaryTextColor}">

                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsExpanded}"
                                                 Value="True">
                                        <Setter Property="Rotation" Value="90"/>
                                    </DataTrigger>
                                </Label.Triggers>

                            </Label>

                        </Grid>
                    </Border>

                    <!-- ================= GROUP LIST ================= -->
                    <StackLayout IsVisible="{Binding IsExpanded}">

                        <CollectionView ItemsSource="{Binding Themes}"
                                        SelectionMode="None">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <StackLayout>

                                        <!-- ===== GROUP HEADER ===== -->
                                        <Border HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='50'}"
                                                Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='2'}"
                                                Stroke="{DynamicResource PrimaryAccent}"
                                                StrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='1'}">

                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='6'}"/>
                                            </Border.StrokeShape>

                                            <Border.Triggers>

                                                <DataTrigger TargetType="Border"
                                                             Binding="{Binding IsExpanded}"
                                                             Value="True">

                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <RadialGradientBrush Center="0,0" Radius="1">
                                                                <GradientStop Color="{DynamicResource SecondaryStart}" Offset="0"/>
                                                                <GradientStop Color="{DynamicResource PrimaryAccent}" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>

                                                </DataTrigger>

                                                <DataTrigger TargetType="Border"
                                                             Binding="{Binding IsExpanded}"
                                                             Value="False">

                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <RadialGradientBrush Center="0,0" Radius="1">
                                                                <GradientStop Color="{DynamicResource SecondaryStart}" Offset="0"/>
                                                                <GradientStop Color="{DynamicResource SecondaryEnd}" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>

                                                </DataTrigger>

                                            </Border.Triggers>

                                            <Grid ColumnDefinitions="*,Auto"
                                                  VerticalOptions="Center"
                                                  ColumnSpacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='10'}">

                                                <Label Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='13'}"
                                                       FontAttributes="Bold"
                                                       TextColor="{DynamicResource PrimaryTextColor}"
                                                       VerticalOptions="Center"
                                                       Margin="15,0,0,7" />

                                                <Label Grid.Column="1"
                                                       Text="›"
                                                       FontSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='26'}"
                                                       FontAttributes="Bold"
                                                       Margin="0,0,15,10"
                                                       HorizontalOptions="End"
                                                       TextColor="{DynamicResource PrimaryTextColor}">

                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding IsExpanded}"
                                                                     Value="True">
                                                            <Setter Property="Rotation" Value="90"/>
                                                        </DataTrigger>
                                                    </Label.Triggers>

                                                </Label>

                                            </Grid>

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ThemeSelectionViewModel}}, Path=ToggleGroupCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>

                                        </Border>

                                        <!-- ===== THEME GRID ===== -->
                                        <CollectionView ItemsSource="{Binding Themes}"
                                                        IsVisible="{Binding IsExpanded}"
                                                        SelectionMode="None">

                                            <CollectionView.ItemsLayout>
                                                <GridItemsLayout Orientation="Vertical"
                                                                 Span="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='2'}"
                                                                 HorizontalItemSpacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='4'}"
                                                                 VerticalItemSpacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='4'}"/>
                                            </CollectionView.ItemsLayout>

                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>

                                                    <controls:ThemeItemView BindingContext="{Binding .}">
                                                        <controls:ThemeItemView.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ThemeSelectionViewModel}}, Path=ThemeSelectedCommand}"
                                                                CommandParameter="{Binding .}" />
                                                        </controls:ThemeItemView.GestureRecognizers>
                                                    </controls:ThemeItemView>

                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>

                                        </CollectionView>

                                    </StackLayout>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </StackLayout>

                </StackLayout>

            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>