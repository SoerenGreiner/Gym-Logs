<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gym_Logs.ViewModel.Pages"
             xmlns:controls="clr-namespace:Gym_Logs.View.Controls"
             x:Class="Gym_Logs.View.Pages.ThemeSelectionView">

    <CollectionView ItemsSource="{Binding ThemeCategories}" SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <StackLayout>
                    <Border HeightRequest="65"
                            Margin="4"
                            Background="{DynamicResource PrimaryBrush}"
                            Stroke="{DynamicResource PrimaryAccent}"
                            StrokeThickness="1">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center" ColumnSpacing="10">
                            <Label Grid.Column="0" 
                                   Text="{Binding Name}"
                                   TextColor="{DynamicResource PrimaryTextColor}"
                                   FontAttributes="Bold"
                                   Margin="15,7,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ThemeSelectionViewModel}}, Path=ToggleCategoryCommand}" 
                                CommandParameter="{Binding .}" />
                            </Label.GestureRecognizers>
                        </Label>
                            <Label Grid.Column="1"
                                   Text="›"
                                   FontSize="26"
                                   Margin="0,0,15,7"
                                   HorizontalOptions="End"
                                   TextColor="{DynamicResource PrimaryTextColor}" >
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="Rotation" Value="90"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="False">
                                        <Setter Property="Rotation" Value="0"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>

                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsExpanded}" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <RadialGradientBrush Center="0,0" Radius="1">
                                            <GradientStop Color="{DynamicResource PrimaryStart}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource PrimaryAccent}" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsExpanded}" Value="False">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <RadialGradientBrush Center="0,0" Radius="1">
                                            <GradientStop Color="{DynamicResource PrimaryStart}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource PrimaryEnd}" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Border.Triggers>

                    </Border>

                    <CollectionView ItemsSource="{Binding Themes}" IsVisible="{Binding IsExpanded}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="4" VerticalItemSpacing="4"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <controls:ThemeItemView BindingContext="{Binding .}">
                                    <controls:ThemeItemView.GestureRecognizers>
                                        <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ThemeSelectionViewModel}}, Path=ThemeSelectedCommand}"
                                        CommandParameter="{Binding .}" />
                                    </controls:ThemeItemView.GestureRecognizers>
                                </controls:ThemeItemView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>