<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gym_Logs.ViewModels"
             x:Class="Gym_Logs.Views.Pages.RegistrationView"
             BackgroundColor="{DynamicResource AppBackgroundColor}">
    
    <StackLayout Padding="20" VerticalOptions="Center">
        <Label Text="E-Mail" />
        <Entry Text="{Binding Email}" Placeholder="email@beispiel.de" Keyboard="Email" />

        <Label Text="Passwort" />
        <Entry Text="{Binding Password}" Placeholder="Passwort" IsPassword="True" />

        <Button Text="Registrieren"
                Command="{Binding RegistrateCommand}" />
    </StackLayout>
</ContentPage>
