<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gym_Logs.ViewModels"
             xmlns:controls="clr-namespace:Gym_Logs.UI.Controls"
             x:Class="Gym_Logs.Views.Pages.SettingsView">

    <!-- ===================== RESOURCES ===================== -->
    <ContentPage.Resources>
        <Style x:Key="ThemePreviewBox" TargetType="Border">
            <!-- Width/Height scaled using UIScale -->
            <Setter Property="WidthRequest" 
                    Value="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=22}" />
            <Setter Property="HeightRequest" 
                    Value="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=22}" />
            <Setter Property="Stroke" Value="Black"/>
            <Setter Property="StrokeThickness" 
                    Value="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=1}" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=4}" />
                </Setter.Value>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <Grid Padding="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=16}"
              RowSpacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=20}"
              RowDefinitions="Auto,Auto,Auto">

            <!-- ================= THEMES ================= -->
            <VerticalStackLayout Grid.Row="0" Spacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=5}">

                <!-- Theme Header -->
                <Border Stroke="{DynamicResource PrimaryAccent}"
                        Background="{DynamicResource PrimaryBrush}"
                        StrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=2}"
                        Padding="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=8}"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=4}" />
                    </Border.StrokeShape>

                    <Label Text="Themes:"
                           FontSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=18}"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource PrimaryTextColor}" />
                </Border>

                <!-- Theme Selection Box -->
                <Border Stroke="{DynamicResource PrimaryAccent}"
                        Background="{DynamicResource SecondaryBrush}"
                        StrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=2}"
                        Padding="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=5}"
                        HorizontalOptions="Fill"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=4}" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=10}">

                        <!-- Current Theme Display -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=10}">
                            <VerticalStackLayout Grid.Column="0">

                                <Label Text="{Binding CurrentTheme.DisplayName}"
                                       FontSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=16}"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource PrimaryTextColor}"
                                       HorizontalOptions="Center"/>

                                <HorizontalStackLayout Spacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=6}"
                                                       HorizontalOptions="Center">
                                    <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{DynamicResource PrimaryStart}" />
                                    <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{DynamicResource PrimaryEnd}" />
                                    <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{DynamicResource SecondaryStart}" />
                                    <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{DynamicResource SecondaryEnd}" />
                                    <Border Style="{StaticResource ThemePreviewBox}" BackgroundColor="{DynamicResource PrimaryAccent}" />
                                </HorizontalStackLayout>

                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="›"
                                   FontSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=26}"
                                   Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='0,0,30,0'}"
                                   TextColor="{DynamicResource PrimaryTextColor}" />

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenThemeSelectionCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=2}"
                                 Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='30,0,30,0'}"
                                 Opacity="0.3"
                                 BackgroundColor="{DynamicResource PrimaryAccent}" />

                        <!-- Brightness Options -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=10}">
                            <controls:CustomRadioButton Grid.Column="0" 
                                                        Text="Light"
                                                        GroupName="Brightness"
                                                        IsSelected="{Binding IsLightSelected, Mode=TwoWay}"
                                                        OuterStrokeColor="{DynamicResource PrimaryAccent}"
                                                        InnerFillColor="{DynamicResource PrimaryAccent}"
                                                        OuterSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=24}"
                                                        InnerSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=14}"
                                                        OuterStrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=2}"/>
                            <controls:CustomRadioButton Grid.Column="1" 
                                                        Text="Normal"
                                                        GroupName="Brightness"
                                                        IsSelected="{Binding IsNormalSelected, Mode=TwoWay}"
                                                        OuterStrokeColor="{DynamicResource PrimaryAccent}"
                                                        InnerFillColor="{DynamicResource PrimaryAccent}"
                                                        OuterSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=24}"
                                                        InnerSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=14}"
                                                        OuterStrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=2}"/>
                            <controls:CustomRadioButton Grid.Column="2" 
                                                        Text="Dark"
                                                        GroupName="Brightness"
                                                        IsSelected="{Binding IsDarkSelected, Mode=TwoWay}"
                                                        OuterStrokeColor="{DynamicResource PrimaryAccent}"
                                                        InnerFillColor="{DynamicResource PrimaryAccent}"
                                                        OuterSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=24}"
                                                        InnerSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=14}"
                                                        OuterStrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=2}"/>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=2}"
                                 Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='30,0,30,0'}"
                                 Opacity="0.3"
                                 BackgroundColor="{DynamicResource PrimaryAccent}" />

                        <!-- Inverted Colors Switch -->
                        <Grid ColumnDefinitions="*,*" HorizontalOptions="Fill" VerticalOptions="Center">
                            <Label Grid.Column="0"
                                   Text="Invertierter Farben"
                                   Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='30,0,30,0'}"
                                   FontSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=16}"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   TextColor="{DynamicResource PrimaryTextColor}" />

                            <controls:CustomSwitch Grid.Column="1"
                                                   HorizontalOptions="End"
                                                   Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='30,0,30,0'}"
                                                   IsToggled="{Binding IsBrushInverted, Mode=TwoWay}" 
                                                   TrackOnColor="{DynamicResource PrimaryAccent}"
                                                   TrackOffColor="{DynamicResource PrimaryEnd}"
                                                   ThumbColor="{DynamicResource SecondaryStart}"
                                                   TrackStrokeColor="{DynamicResource PrimaryAccent}"
                                                   TrackStrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=1}"
                                                   ThumbStrokeColor="{DynamicResource PrimaryAccent}"
                                                   ThumbStrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=0.5}"/>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=2}"
                                 Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='30,0,30,0'}"
                                 Opacity="0.3"
                                 BackgroundColor="{DynamicResource PrimaryAccent}" />

                        <!-- Inverted Gradient Switch -->
                        <Grid ColumnDefinitions="*,*" HorizontalOptions="Fill" VerticalOptions="Center">
                            <Label Grid.Column="0"
                                   Text="Invertierter Farbverlauf"
                                   FontSize="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=16}"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='30,0,10,10'}"
                                   TextColor="{DynamicResource PrimaryTextColor}" />

                            <controls:CustomSwitch Grid.Column="1"
                                                   HorizontalOptions="End"
                                                   Margin="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='0,0,30,0'}"
                                                   IsToggled="{Binding AreBrushStartPointsInverted, Mode=TwoWay}" 
                                                   TrackOnColor="{DynamicResource PrimaryAccent}"
                                                   TrackOffColor="{DynamicResource PrimaryEnd}"
                                                   ThumbColor="{DynamicResource SecondaryStart}"
                                                   TrackStrokeColor="{DynamicResource PrimaryAccent}"
                                                   TrackStrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=1}"
                                                   ThumbStrokeColor="{DynamicResource PrimaryAccent}"
                                                   ThumbStrokeThickness="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=0.5}"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ================= DIVIDER ROW ================= -->
            <BoxView Grid.Row="1"
                     HeightRequest="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter=1}"
                     BackgroundColor="{DynamicResource InactiveStart}" />

            <!-- ================= GENERAL (placeholder for later) ================= -->
            <VerticalStackLayout Grid.Row="2">
                <!-- später: Sprache, Schriftart usw -->
            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>