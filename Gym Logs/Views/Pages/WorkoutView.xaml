<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Gym_Logs.UI.Controls"
             xmlns:pages="clr-namespace:Gym_Logs.Views.Pages"
             x:Class="Gym_Logs.Views.Pages.WorkoutView"
             Title="Workout">

    <Grid RowDefinitions="*,Auto">
        <!-- TabBar -->
        <controls:CustomTabBarView Grid.Row="0"
                                   Items="{Binding Tabs}"
                                   IsVisible="{Binding IsTabBarVisible}"
                                   VerticalOptions="Start"
                                   HeightRequest="60"/>
        
        <!-- Dynamischer Content -->
        <ContentView Grid.Row="1" 
                     Content="{Binding CurrentContent}" />

        
    </Grid>
</ContentPage>
