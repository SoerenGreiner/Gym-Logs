<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Gym_Logs.ViewModels.Pages"
             x:Class="Gym_Logs.Views.Pages.WorkoutView"
             Title="Workout"
             BackgroundColor="{DynamicResource Background}">

    <Grid RowDefinitions="*,Auto" Padding="10">

        <!-- Scrollbare Liste der Workout Entries -->
        <CollectionView Grid.Row="0" ItemsSource="{Binding Entries}" SelectionMode="None" Margin="0,0,0,10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="{DynamicResource Accent}" StrokeThickness="1" Padding="10" Background="{DynamicResource SecondaryBrush}">
                        <Grid ColumnDefinitions="*,Auto">

                            <Label Text="{Binding DisplayName}" 
                                   FontAttributes="Bold" 
                                   FontSize="18" 
                                   TextColor="{DynamicResource PrimaryTextColor}"/>

                            <!-- Edit Button -->
                            <Button Grid.Column="1"
                                    Text="✏"
                                    Background="Transparent"
                                    FontSize="24"
                                    Command="{Binding EditEntryCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom FAB für neue Übung -->
        <Button Grid.Row="1"
                Text="➕"
                CornerRadius="30"
                HorizontalOptions="End"
                VerticalOptions="End"
                WidthRequest="60"
                HeightRequest="60"
                Background="{DynamicResource SecondaryBrush}"
                TextColor="{DynamicResource PrimaryAccent}"
                Command="{Binding AddNewEntryCommand}"/>
    </Grid>
</ContentPage>
