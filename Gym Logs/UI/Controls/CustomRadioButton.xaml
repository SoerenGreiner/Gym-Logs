<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Gym_Logs.UI.Controls.CustomRadioButton"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">

    <Border Padding="5"
            StrokeThickness="0"
            Stroke="Transparent"
            StrokeShape="RoundRectangle 12">

        <Grid>
            <HorizontalStackLayout Spacing="10"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">

                <Grid WidthRequest="{Binding Source={x:Reference Root}, Path=OuterSize}"
                      HeightRequest="{Binding Source={x:Reference Root}, Path=OuterSize}">

                    <Ellipse Stroke="{Binding Source={x:Reference Root}, Path=OuterStrokeColor}"
                             StrokeThickness="{Binding Source={x:Reference Root}, Path=OuterStrokeThickness}"
                             Fill="Transparent" />

                    <Ellipse x:Name="InnerCircle"
                             WidthRequest="{Binding Source={x:Reference Root}, Path=InnerSize}"
                             HeightRequest="{Binding Source={x:Reference Root}, Path=InnerSize}"
                             Fill="{Binding Source={x:Reference Root}, Path=InnerFillColor}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             IsVisible="False"/>
                </Grid>

                <Label FontSize="16"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       Text="{Binding Source={x:Reference Root}, Path=Text}" />

            </HorizontalStackLayout>
        </Grid>

        <Border.GestureRecognizers>
            <TapGestureRecognizer
                Command="{Binding Source={x:Reference Root}, Path=SelectCommand}" />
        </Border.GestureRecognizers>

    </Border>
</ContentView>