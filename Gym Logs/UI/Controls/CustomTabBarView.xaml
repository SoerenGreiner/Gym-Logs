<ContentView
    x:Class="Gym_Logs.UI.Controls.CustomTabBarView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="This"
    HeightRequest="60">

    <Grid x:Name="GridContainer"
          Background="{DynamicResource SecondaryBrush}">

        <BindableLayout.ItemsSource>
            <Binding Source="{x:Reference This}" Path="Items"/>
        </BindableLayout.ItemsSource>

        <BindableLayout.ItemTemplate>
            <DataTemplate>
                <Border x:Name="TabItem"
                        Padding="10"
                        BackgroundColor="Transparent"
                        Stroke="Transparent">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="{Binding Source={StaticResource UIScale}, Converter={StaticResource ScaleConverter}, ConverterParameter='6'}"/>
                    </Border.StrokeShape>

                    <Grid RowDefinitions="*,8"
                          HorizontalOptions="Center"
                          VerticalOptions="Center">

                        <!-- Icon + Text -->
                        <HorizontalStackLayout Grid.Row="0"
                                               Spacing="5"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Label Text="{Binding Icon}"
                                   FontSize="20"
                                   FontAttributes="Bold"/>
                            <Label Text="{Binding Title}"
                                   FontSize="14"
                                   FontAttributes="Bold"/>
                        </HorizontalStackLayout>

                        <!-- Unterstrich -->
                        <BoxView Grid.Row="1"
                                 HeightRequest="5"
                                 CornerRadius="3"
                                 Margin="0"
                                 BackgroundColor="{DynamicResource PrimaryAccent}"
                                 IsVisible="{Binding IsSelected}" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabTapped"
                                              Command="{Binding Command}"
                                              CommandParameter="{Binding .}" />
                    </Border.GestureRecognizers>

                </Border>
            </DataTemplate>
        </BindableLayout.ItemTemplate>
    </Grid>
</ContentView>